 RowBox[{
  RowBox[{"Tensor", "[", 
   RowBox[{"g", ",", 
    RowBox[{"{", 
     RowBox[{"M", ",", "N"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"Void", ",", "Void"}], "}"}]}], "]"}], "==", 
  RowBox[{"Kronecker", "[", 
   RowBox[{"M", ",", "N"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Tensor", "[", 
   RowBox[{"g", ",", 
    RowBox[{"{", 
     RowBox[{"m", ",", "n"}], "}"}], ",", 
    RowBox[{"{", 

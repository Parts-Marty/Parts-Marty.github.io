  RowBox[{
   UnderscriptBox["\[Sum]", "M"], 
   RowBox[{
    RowBox[{"IndexDerivative", "[", 
     RowBox[{
      RowBox[{
       OverscriptBox["x", "_"], "[", "M", "]"}], ",", 
      RowBox[{"x", "[", "m", "]"}]}], "]"}], 
    RowBox[{"IndexDerivative", "[", 
     RowBox[{
      RowBox[{

   RowBox[{
    RowBox[{"Cos", "[", "\[Phi]", "]"}], 
    RowBox[{"Tensor", "[", 
     RowBox[{"e", ",", 
      RowBox[{"{", "x", "}"}], ",", 
      RowBox[{"{", "Void", "}"}]}], "]"}]}], "+", 
   RowBox[{
    RowBox[{"Sin", "[", "\[Phi]", "]"}], 
    RowBox[{"Tensor", "[", 
     RowBox[{"e", ",", 
      RowBox[{"{", "y", "}"}], ",", 
      RowBox[{"{", "Void", "}"}]}], "]"}]}]}]}], "\[IndentingNewLine]", 

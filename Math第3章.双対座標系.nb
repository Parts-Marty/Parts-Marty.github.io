 RowBox[{"r1", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"x", "[", "1", "]"}], "->", 
     RowBox[{
      RowBox[{
       OverscriptBox["x", "_"], "[", "1", "]"}], 
